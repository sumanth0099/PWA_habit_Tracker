# PWA Habit Tracker - Environment Variables
# Copy this file to .env and fill in your real values.
# Generate VAPID keys by running: npx web-push generate-vapid-keys

# Port on which the push notification server will run
PORT=3001

# VAPID Public Key for Web Push (base64url encoded)
VAPID_PUBLIC_KEY=your_vapid_public_key_here

# VAPID Private Key for Web Push (base64url encoded, keep SECRET)
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# Email address for VAPID identification (used by push services to contact you)
VAPID_EMAIL=mailto:admin@example.com
